NODE_ENV=production
PORT=4178

# Linux server paths
PREP_WORKSPACE=/home/kunya/lesson-prep
PREP_MATERIAL_ROOT=/home/kunya/lesson-prep/资料库
APP_DATA_DIR=/home/kunya/lesson-prep-web/data

# Codex runner
CODEX_COMMAND=codex
CODEX_MODEL=
CODEX_AUTO_RUN=true
CODEX_RUNNER=local

# If the web app runs on Windows or another host but Codex must run on Linux:
# CODEX_RUNNER=ssh
# CODEX_SSH_HOST=your-linux-host
# CODEX_SSH_USER=kunya
# CODEX_SSH_PORT=22
# CODEX_SSH_KEY=/home/kunya/.ssh/id_ed25519
# CODEX_REMOTE_WORKSPACE=/home/kunya/lesson-prep
# CODEX_REMOTE_PROJECT_ROOT=/home/kunya/lesson-prep-web
# CODEX_REMOTE_COMMAND=codex

# Upload and indexing limits
MAX_UPLOAD_FILES=5000
RAG_MAX_REINDEX_FILES=300

# Security
# If serving through HTTPS, set SECURE_COOKIES=true.
# If Nginx is the only public entrypoint, set TRUST_PROXY=true so rate limits use real client IPs.
SECURE_COOKIES=false
ENABLE_HSTS=false
TRUST_PROXY=true
AUTH_RATE_LIMIT_MAX=8
AUTH_RATE_LIMIT_WINDOW_MS=600000

# Feishu cloud sync via the currently logged-in lark-cli user.
# Run `lark-cli auth login --recommend` on the server before enabling sync.
FEISHU_LESSON_PARENT_FOLDER_TOKEN=LY9efBiWjlEAQWdqPrucuLl4nic
FEISHU_NOTIFY_OPEN_ID=
FEISHU_SYNC_ENABLED=true
FEISHU_LESSON_CALENDAR_ENABLED=true
# Optional. Leave blank to create on the current user's primary calendar.
FEISHU_LESSON_CALENDAR_ID=
# Optional comma-separated open_ids/chat_ids/room_ids, e.g. ou_xxx,oc_xxx,omm_xxx.
FEISHU_LESSON_CALENDAR_ATTENDEE_IDS=
