NODE_ENV=production
PORT=4178
PREP_WORKSPACE=C:\Users\kunya\Documents\备课
PREP_MATERIAL_ROOT=C:\Users\kunya\Documents\备课\资料库
APP_DATA_DIR=./data
CODEX_COMMAND=codex
CODEX_MODEL=
CODEX_AUTO_RUN=true
CODEX_RUNNER=local
# 如果 Web 服务不在 Linux 上，但要远程调用 Linux 服务器上的 Codex：
# CODEX_RUNNER=ssh
# CODEX_SSH_HOST=your-linux-host
# CODEX_SSH_USER=root
# CODEX_SSH_PORT=22
# CODEX_SSH_KEY=/path/to/private_key
# CODEX_REMOTE_WORKSPACE=/home/you/lesson-prep
# CODEX_REMOTE_PROJECT_ROOT=/home/you/lesson-prep-web
# CODEX_REMOTE_COMMAND=codex
RAG_MAX_REINDEX_FILES=300
MAX_UPLOAD_FILES=5000

# Security
# 本地 HTTP 测试保持 false；公网 HTTPS 后建议 true。
SECURE_COOKIES=false
ENABLE_HSTS=false
TRUST_PROXY=false
AUTH_RATE_LIMIT_MAX=8
AUTH_RATE_LIMIT_WINDOW_MS=600000
